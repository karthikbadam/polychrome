{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "exactOptionalPropertyTypes": true,
    "useUnknownInCatchVariables": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "isolatedModules": true,
    "paths": {
      "@polychrome/protocol": ["./packages/protocol/src/index.ts"],
      "@polychrome/ot-core": ["./packages/ot-core/src/index.ts"],
      "@polychrome/replay-player": ["./packages/replay-player/src/index.ts"],
      "@polychrome/sdk": ["./packages/sdk/src/index.ts"]
    }
  },
  "exclude": ["**/node_modules", "**/dist", "legacy"]
}
