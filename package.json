{
  "name": "polychrome",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "preview": "PC_PUBLISH_BASE=/ bash scripts/build-gh-pages.sh && npx --yes serve gh-pages-out -p 5180",
    "format": "prettier --write ."
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^9.26.0",
    "eslint-plugin-import": "^2.32.0",
    "prettier": "^3.8.3",
    "turbo": "2.9.6",
    "typescript": "~5.8.3",
    "vitest": "^4.1.5"
  }
}
